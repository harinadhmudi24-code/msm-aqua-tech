rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the data belongs to the logged-in user
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && (!request.resource.data.keys().hasAny(['taxAccountBalance']) || request.resource.data.taxAccountBalance == 0);
      allow update: if isAuthenticated() && isOwner(userId) && (!request.resource.data.keys().hasAny(['taxAccountBalance']) || request.resource.data.taxAccountBalance == resource.data.taxAccountBalance);
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // Posts/Items Collection
    match /posts/{postId} {
      allow read, write: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Analytics/Logs Collection
    match /analytics/{logId} {
      allow create: if isAuthenticated(); // Allow logged-in users to write logs
      allow read, update, delete: if false; // Block reading/modifying logs directly from frontend
    }

    // Tax Deposits Collection (Immutable, written only via backend transaction)
    match /tax_deposits/{depositId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // System Config Collection (Global settings, read-only for authenticated users)
    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Scanned Payments Collection (Audit ledger, read-only for authenticated users)
    match /scanned_payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
